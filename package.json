{
  "name": "@jvzhu/cli-tool",
  "version": "0.1.0",
  "description": "TypeScript command-line utility tool",
  "main": "dist/index.js",
  "scripts": {
    "test": "npm run build && NODE_OPTIONS=--experimental-vm-modules jest --runInBand",
    "build": "tsc -p tsconfig.json",
    "dev": "ts-node src/index.ts",
    "test:watch": "jest --watch",
    "lint": "tsc --noEmit -p tsconfig.json",
    "prepare": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jvzhu/cli-tool.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/jvzhu/cli-tool/issues"
  },
  "homepage": "https://github.com/jvzhu/cli-tool#readme",
  "type": "module",
  "bin": {
    "cli-tool": "dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "ajv": "^8.20.0",
    "axios": "^1.18.0",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "cli-table3": "^0.6.5",
    "commander": "^15.0.0",
    "csv-parse": "^7.0.0",
    "csv-stringify": "^6.8.0",
    "dotenv": "^17.4.2",
    "fs-extra": "^11.3.5",
    "glob": "^13.0.6",
    "inquirer": "^14.0.2",
    "js-yaml": "^5.0.0",
    "ora": "^9.4.1",
    "p-limit": "^7.3.0",
    "update-notifier": "^7.3.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.0.0",
    "@types/update-notifier": "^6.0.8",
    "execa": "^9.6.1",
    "jest": "^29.7.0",
    "memfs": "^4.57.8",
    "nock": "^14.0.15",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
